# Copy to .env next to docker-compose.yml (optional). Compose loads .env automatically.
#
# Put WEATHER_API_KEY in weather-backend/.env (not here). An empty WEATHER_API_KEY= in this
# file used to override the backend container and hide the key — the stack now reads weather-backend/.env.

# Host port mapped to Flask/gunicorn (browser API: http://127.0.0.1:5000/api when default).
BACKEND_PORT=5000

# API base URL baked into the frontend at image build time (browser must reach this host).
# If you change BACKEND_PORT, set this to match and run: docker compose build --no-cache frontend
VITE_API_BASE_URL=http://127.0.0.1:5000/api

# Host port mapped to nginx inside the container (browser: http://127.0.0.1:8080/ or http://localhost:8080/)
FRONTEND_PORT=8080

# Optional: comma-separated origins for CORS (see weather-backend/.env.example). Leave empty for permissive dev default.
# CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
