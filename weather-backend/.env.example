WEATHER_API_KEY=

# Seconds to cache identical city / coordinate lookups (default 300)
WEATHER_CACHE_TTL=300

# Optional: comma-separated browser origins for CORS (leave empty for permissive dev default)
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Per-IP limit for GET /api/weather (Flask-Limiter syntax)
# RATE_LIMIT_WEATHER=60 per minute

# LOG_LEVEL=INFO

# SECRET_KEY=use-a-long-random-string-in-production
